# ============================================
# AI Chatbot MVP - Environment Configuration
# ============================================
# Copy this file to .env and update the values

# ----- Django Settings -----
SECRET_KEY=your-super-secret-django-key-change-this
DEBUG=True
DJANGO_PORT=8000
ALLOWED_HOSTS=*

# ----- PostgreSQL Settings -----
POSTGRES_DB=chatbot
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot123
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ----- Ollama AI Settings -----
# URL of your Ollama instance (change if Ollama is on a different host)
# Use http://host.docker.internal:11434 when running in Docker
# Use http://localhost:11434 when running locally without Docker
OLLAMA_BASE_URL=http://host.docker.internal:11434
# LLM model name (must be pulled in Ollama: ollama pull llama3.2)
OLLAMA_LLM_MODEL=llama3.2
# Embedding model name (must be pulled in Ollama: ollama pull nomic-embed-text)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Generation parameters
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=2048

# ----- RAG Settings -----
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
VECTOR_SEARCH_TOP_K=5

# ----- CORS -----
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ----- Frontend -----
FRONTEND_PORT=3000
